# AIRO — AI Research Orchestrator
# Copy this file to .env and fill in your values.

GROQ_API_KEY=your-groq-api-key-here
MLFLOW_TRACKING_URI=sqlite:///mlruns.db   # No server needed — auto-created
AIRO_PARALLEL_WORKERS=4
AIRO_MODEL=llama-3.3-70b-versatile
AIRO_SKIP_CURVES=false   # Set to true to skip learning curves (~60% faster)
AIRO_SKIP_SHAP=false     # Set to true to skip SHAP explainability in report
